SELECT DISTINCT b.SUBMARKET_CODE
          INTO V_SUBMARKET_CODE
          FROM tblSITE_ZITE a
          JOIN SPDB_NOTIFICATION_CONFIG b
            ON a.mkt_id = b.market
         WHERE a.enodeb = IN_GNODEB
         LIMIT 1;


V_SUBMARKET_CODE VARCHAR(50);
    V_TABLE_NAME VARCHAR(200);
    V_SQL LONGTEXT;
