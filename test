  AND X.ECMS_PROJECT_NUM = WO.ECMS_PROJECT_NUM
  AND X.WORK_ORDER_NUM = WO.WORK_ORDER_NUM
  AND Y.ECMS_PROJECT_NUM = WO.ECMS_PROJECT_NUM
  AND Y.WO_AUTH_NUM = WO.WO_AUTH_NUM
ORDER BY Y.WO_AUTH_NUM, Y.CL_LINE_NUM;
